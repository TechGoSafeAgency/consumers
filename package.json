{
  "name": "@go-safe/consumer",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.2",
  "description": "Consumer for Go Safe project",
  "main": "dist/app.js",
  "types": "dist/app.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "Dockerfile",
    "docker-compose.yml"
  ],
  "scripts": {
    "build": "tsc && tsc-alias",
    "clean": "rm -rf dist",
    "consumer:get-driver-verisk": "node dist/consumers/get-driver-verisk-queue.consumer.js",
    "docker:build": "docker build -t truffa-api:latest .",
    "docker:run": "docker run --rm -p 3000:3000 -e NODE_ENV=production -e PORT=3000 truffa-api:latest",
    "docker:compose": "docker compose up --build",
    "docker:compose:up": "docker compose up -d --build",
    "docker:compose:down": "docker compose down",
    "docker:compose:logs": "docker compose logs -f api",
    "docs:validate": "pnpm run build && node -e \"require('./dist/docs/openapi').getOpenApiSpec(); console.log('OpenAPI spec generated successfully')\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --cache --cache-location .eslintcache --no-warn-ignored",
    "lint:fix": "eslint . --fix --cache --cache-location .eslintcache --no-warn-ignored",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test",
    "e2e:production-workflow": "node scripts/e2e-production-workflow.mjs",
    "prepublishOnly": "pnpm run validate && pnpm run build",
    "publish:npm": "pnpm publish --access public --no-git-checks",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md}": "prettier --write"
  },
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=9"
  },
  "keywords": [
    "types",
    "typescript",
    "shared"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.0",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@hapi/boom": "10.0.1",
    "amqplib": "^2.0.1",
    "axios": "^1.18.1",
    "dotenv": "16.6.1",
    "helmet": "8.1.0",
    "jose": "6.1.3",
    "moment": "2.30.1",
    "mongodb": "6.21.0",
    "soap": "^1.10.0",
    "uuid": "11.1.1",
    "winston": "3.18.3"
  }
}